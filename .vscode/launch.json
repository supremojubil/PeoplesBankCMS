{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run PHP Built-in Server (8000)",
      "type": "php",
      "request": "launch",
      "runtimeArgs": ["-S", "localhost:8000", "-t", "${workspaceFolder}"],
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "Development Server .*http://localhost:8000.*",
        "uriFormat": "http://localhost:8000"
      }
    },
    {
      "name": "Listen for Xdebug",
      "type": "php",
      "request": "launch",
      "port": 9003
    }
  ],
  "compounds": [
    {
      "name": "Server + Debug",
      "configurations": ["Run PHP Built-in Server (8000)", "Listen for Xdebug"]
    }
  ]
}
